{
  "id": "slicer3d_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "3D Slicer environment for medical image visualization, analysis, and segmentation tasks",
  "category": "medical-imaging",
  "tags": [
    "linux",
    "medical",
    "imaging",
    "dicom",
    "segmentation",
    "visualization",
    "3d",
    "desktop"
  ],
  "diagnostics": true,
  "licence": "BSD",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://www.slicer.org/",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/slicer3d_env/artifacts",
    "video_fps": 10,
    "video_resolution": [
      1920,
      1080
    ],
    "video_codec": "libx264",
    "video_crf": 23,
    "audio_rate": 44100,
    "audio_channels": 2,
    "audio_codec": "aac"
  },
  "vnc": {
    "enable": false,
    "host_port": 5954,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/slicer3d_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/slicer3d_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/slicer3d_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/slicer3d_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/slicer3d_env/assets",
      "target": "/workspace/assets",
      "mode": "rw"
    },
    {
      "source": "benchmarks/cua_world/environments/slicer3d_env/data_cache",
      "target": "/var/cache/slicer-data",
      "mode": "rw"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_slicer.sh",
    "post_start": "/workspace/scripts/setup_slicer.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "SLICER_USER": "ga"
        }
      }
    }
  ]
}
